{
  "name": "cuida",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "preinstall": "node scripts/ensure-pnpm.js",
    "dev": "node scripts/ensure-pnpm.js && next dev",
    "build": "node scripts/ensure-pnpm.js && next build",
    "start": "node scripts/ensure-pnpm.js && next start",
    "db:generate": "node scripts/ensure-pnpm.js && prisma generate",
    "db:migrate": "node scripts/ensure-pnpm.js && prisma migrate dev",
    "db:push": "node scripts/ensure-pnpm.js && prisma db push",
    "db:seed": "node scripts/ensure-pnpm.js && prisma db seed"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "prisma": "^6.19.3",
    "tailwindcss": "^4"
  }
}
